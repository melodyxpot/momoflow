# ====== API (apps/api) ======
NODE_ENV=development
PORT=4000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/momoflow

# Redis
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=replace_me_with_a_long_random_string
JWT_EXPIRES_IN=7d

# Public base URL of the redirect engine (no trailing slash)
PUBLIC_BASE_URL=http://localhost:4000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# CORS
CORS_ORIGIN=http://localhost:3000

# ====== WEB (apps/web) ======
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SHORT_DOMAIN=http://localhost:4000
