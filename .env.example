# ─────────────────────────────────────────────────────────────────────────────
#  MomoLinks — single root .env (copy to `.env`)
#
#  Both apps (apps/api and apps/web) read this file automatically via
#  the loaders in apps/api/src/config/env.ts and apps/web/next.config.mjs.
#  No more per-app .env / .env.local files.
# ─────────────────────────────────────────────────────────────────────────────

# ─── API (apps/api) ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000

# Datastores
MONGODB_URI=mongodb://localhost:27017/momolinks
REDIS_URL=redis://localhost:6379

# Auth
JWT_SECRET=change_me_to_a_long_random_string_min_16_chars
JWT_EXPIRES_IN=7d

# Public hostname of the redirect engine (no trailing slash).
# Whatever you put here is stamped into every generated short link.
PUBLIC_BASE_URL=http://localhost:4000

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# CORS — comma-separated list of allowed origins for the dashboard
CORS_ORIGIN=http://localhost:3000

# Landing page (Express "/" route)
BRAND_NAME=MomoLinks
DASHBOARD_URL=http://localhost:3000

# ─── WEB (apps/web) ─────────────────────────────────────────────────────────
# Where the dashboard calls the REST API
NEXT_PUBLIC_API_URL=http://localhost:4000
# Domain the dashboard displays / copies for generated short links
NEXT_PUBLIC_SHORT_DOMAIN=http://localhost:4000

# ─── PRODUCTION (momolinks.io) example ───────────────────────────────────────
# NODE_ENV=production
# PUBLIC_BASE_URL=https://momolinks.io
# CORS_ORIGIN=https://app.momolinks.io
# DASHBOARD_URL=https://app.momolinks.io
# NEXT_PUBLIC_API_URL=https://momolinks.io
# NEXT_PUBLIC_SHORT_DOMAIN=https://momolinks.io
